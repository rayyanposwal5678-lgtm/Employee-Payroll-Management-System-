# Environment variables for Employee Payroll Management System
# Copy this file to .env and fill in the values for your environment
# NOTE: Never commit the .env file with real values to version control

# Django Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-here-change-in-production-use-a-secure-random-string

# Allowed Hosts (comma-separated for multiple domains)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.vercel.app,www.yourdomain.com

# CSRF Trusted Origins (for HTTPS requests from specific domains)
CSRF_TRUSTED_ORIGINS=https://yourdomain.vercel.app,https://www.yourdomain.com

# Database Configuration (Optional - defaults to SQLite)
# For PostgreSQL on Vercel:
# DATABASE_URL=postgresql://user:password@host:port/dbname
# OR use individual settings:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=epms_db
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432
